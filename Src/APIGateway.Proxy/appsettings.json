{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://tranzrmoves.com",
      "https://tranzrgroup.com",
      "https://tranzzer.com"
    ]
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "address-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/address/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "map-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/map/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "role-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/auth/role"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-auth-context-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/Auth/context"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-auth-accept-invitation-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/Auth/accept-invitation"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-auth-profile-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/Auth/profile"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "auth-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "checkout-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/checkout/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "checkout-routev2": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v2/checkout/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "additional-prices-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/additionalprices/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "prices-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/prices/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "legal-anonymous-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/legal/terms-and-conditions",
          "Methods": ["GET"]
        },
        "AuthorizationPolicy": "anonymous"
      },
      "legal-anonymous-route-privacy": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/legal/privacy-policy",
          "Methods": ["GET"]
        },
        "AuthorizationPolicy": "anonymous"
      },
      "legal-authenticated-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/legal/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "servicefeatures-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/servicefeatures/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "ratecards-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/ratecards/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "customer-jobs-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/customer-jobs/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-accounts-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/BusinessAccounts/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-users-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/BusinessUsers/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-dashboard-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/BusinessDashboard/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-bookings-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/BusinessBookings/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-locations-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/BusinessLocations/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-contacts-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/BusinessContacts/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "job-templates-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/JobTemplates/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-quote-sessions-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/BusinessQuoteSessions/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "business-checkout-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/BusinessCheckout/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "driver-jobs-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/driver-jobs/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "guest-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/quote/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "quote-route-v2": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v2/quote/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "email-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/email/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "inventory-import-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/inventory",
          "Methods": ["POST"]
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "inventory-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/inventory/{**catch-all}",
          "Methods": ["GET", "POST"]
        },
        "AuthorizationPolicy": "anonymous"
      }
    },
    "Clusters": {
      "tranzr-cluster": {
        "Destinations": {
          "ai": {
            "Address": "http://tranzr-service:80/"
          }
        }
      }
    }
  }
}
