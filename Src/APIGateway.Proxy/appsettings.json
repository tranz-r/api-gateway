{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [ 
      "http://localhost:3000",
      "http://localhost:3001" , 
      "https://tranzrmoves.com"
      ]
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "address-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/address/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "map-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/map/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "role-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/auth/role"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "auth-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "checkout-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/checkout/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "additional-prices-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/additionalprices/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "prices-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/prices/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      },
      "legal-anonymous-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/legal/terms-and-conditions",
          "Methods": ["GET"]
        },
        "AuthorizationPolicy": "anonymous"
      },
      "legal-anonymous-route-privacy": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/legal/privacy-policy",
          "Methods": ["GET"]
        },
        "AuthorizationPolicy": "anonymous"
      },
      "legal-authenticated-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/legal/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "servicefeatures-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/servicefeatures/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "ratecards-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/ratecards/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "customer-jobs-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/customer-jobs/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "driver-jobs-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/v1/driver-jobs/{**catch-all}"
        },
        "AuthorizationPolicy": "AuthenticatedPolicy"
      },
      "guest-route": {
        "ClusterId": "tranzr-cluster",
        "Match": {
          "Path": "/api/guest/{**catch-all}"
        },
        "AuthorizationPolicy": "anonymous"
      }
    },
    "Clusters": {
      "tranzr-cluster": {
        "Destinations": {
          "ai": {
            "Address": "http://tranzr-service:80/"
          }
        }
      }
    }
  }
}
